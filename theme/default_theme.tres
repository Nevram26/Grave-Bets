corner_radius_bottom_right = 8
corner_radius_bottom_left = 8

[resource]
default_font = SubResource("SystemFont_default")
default_font_size = 16
Button/colors/font_color = Color(1, 1, 1, 1)
Button/colors/font_hover_color = Color(1, 0.8, 0.2, 1)
Button/colors/font_pressed_color = Color(1, 0.9, 0.5, 1)
